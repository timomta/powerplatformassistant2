<section class="card border-0 bg-body-tertiary mb-4" role="region" aria-labelledby="authoring-route-heading" aria-describedby="authoring-route-description">
    <div class="card-body">
        <h3 id="authoring-route-heading" class="h5">Authoring Route</h3>
        <p id="authoring-route-description" class="text-muted mb-3">Pin whether you are building a new app or modifying an existing one so the assistant can keep the next steps on the right branch.</p>

        <EditForm Model="_request" FormName="authoring-route" OnValidSubmit="HandleSubmitAsync">
            <fieldset class="border-0 p-0 m-0">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="authoringFlowType">Route</label>
                    <InputSelect id="authoringFlowType" class="form-select" @bind-Value="_request.FlowType" aria-describedby="authoring-route-help">
                        <option value="new-app">New app</option>
                        <option value="existing-app">Existing app</option>
                    </InputSelect>
                    <div id="authoring-route-help" class="form-text">Switching routes resets the assistant to the right authoring branch without leaking prior assumptions.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="environmentType">Environment Type</label>
                    <InputText id="environmentType" class="form-control" @bind-Value="_request.EnvironmentType" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="region">Region</label>
                    <InputText id="region" class="form-control" @bind-Value="_request.Region" />
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <label class="form-label" for="appName">App Name</label>
                    <InputText id="appName" class="form-control" @bind-Value="_request.AppName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="appIdentifier">App Identifier</label>
                    <InputText id="appIdentifier" class="form-control" @bind-Value="_request.AppIdentifier" />
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <label class="form-label" for="screenName">Target Screen</label>
                    <InputText id="screenName" class="form-control" @bind-Value="_request.ScreenName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="environmentId">Environment Id</label>
                    <InputText id="environmentId" class="form-control" @bind-Value="_request.EnvironmentId" />
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label" for="currentGoal">Current Goal</label>
                <InputTextArea id="currentGoal" class="form-control" @bind-Value="_request.CurrentGoal" />
            </div>

            <div class="mt-3">
                <label class="form-label" for="capabilitySummary">Capability Summary</label>
                <InputTextArea id="capabilitySummary" class="form-control" @bind-Value="_request.CapabilitySummary" />
            </div>

            <div class="form-check mt-3">
                <InputCheckbox id="routeConfirmed" class="form-check-input" @bind-Value="_request.IsRouteConfirmed" />
                <label class="form-check-label" for="routeConfirmed">I want the assistant to stay on this authoring route until I switch it.</label>
            </div>

            <div class="form-check mt-2">
                <InputCheckbox id="creationUncertainty" class="form-check-input" @bind-Value="_request.HasCreationCapabilityUncertainty" />
                <label class="form-check-label" for="creationUncertainty">The environment might restrict starter templates or creation options.</label>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <small class="text-muted" aria-live="polite">Current route: @(string.IsNullOrWhiteSpace(CurrentFlowType) ? "not set" : CurrentFlowType).</small>
                <button type="submit" class="btn btn-outline-primary">Save Authoring Route</button>
            </div>
            </fieldset>
        </EditForm>
    </div>
</section>

@code {
    private readonly AuthoringContextRequest _request = new();

    [Parameter]
    public PowerPlatformAssistant.Web.Models.AppContext? AppContext { get; set; }

    [Parameter]
    public EnvironmentContext? EnvironmentContext { get; set; }

    [Parameter]
    public string? CurrentFlowType { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<AuthoringContextRequest> OnSaved { get; set; }

    protected override void OnParametersSet()
    {
        _request.FlowType = AppContext?.FlowType ?? (CurrentFlowType == "existing-app" ? "existing-app" : "new-app");
        _request.AppName = AppContext?.AppName ?? string.Empty;
        _request.AppIdentifier = AppContext?.AppIdentifier ?? string.Empty;
        _request.ScreenName = AppContext?.ScreenName ?? string.Empty;
        _request.CurrentGoal = AppContext?.CurrentGoal ?? string.Empty;
        _request.IsRouteConfirmed = AppContext?.IsRouteConfirmed ?? false;
        _request.EnvironmentId = EnvironmentContext?.EnvironmentId ?? string.Empty;
        _request.EnvironmentType = EnvironmentContext?.EnvironmentType ?? string.Empty;
        _request.Region = EnvironmentContext?.Region ?? string.Empty;
        _request.CapabilitySummary = EnvironmentContext?.CapabilitySummary ?? string.Empty;
        _request.HasCreationCapabilityUncertainty = EnvironmentContext?.HasCreationCapabilityUncertainty ?? false;
    }

    private Task HandleSubmitAsync()
    {
        return OnSaved.InvokeAsync(_request);
    }
}