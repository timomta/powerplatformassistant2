<article class="assistant-message card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
            <strong class="text-uppercase small text-muted">Assistant</strong>
            @if (Turn.HasScopeBoundaryMessage)
            {
                <span class="badge text-bg-warning">Scope Boundary</span>
            }
            else if (Turn.HasClarifyingQuestion)
            {
                <span class="badge text-bg-info">Clarifying Question</span>
            }
            else if (Turn.HasChecklistOutput)
            {
                <span class="badge text-bg-success">Next Step</span>
            }
        </div>

        <p class="mb-0">@Turn.MessageText</p>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public ConversationTurn Turn { get; set; } = default!;
}