<section class="card border-0 bg-body-tertiary mb-4" role="region" aria-labelledby="debugging-context-heading" aria-describedby="debugging-context-description">
    <div class="card-body">
        <h3 id="debugging-context-heading" class="h5">Screenshot Debugging Context</h3>
        <p id="debugging-context-description" class="text-muted mb-3">Upload the screenshot artifact on the server, then record the visible issue and data-source notes so debugging guidance stays tied to evidence instead of guesses.</p>

        <EditForm Model="_request" FormName="debugging-context" OnValidSubmit="HandleSubmitAsync">
            <fieldset class="border-0 p-0 m-0" aria-describedby="debug-upload-help">
                <legend class="form-label fs-6">Screenshot Artifact</legend>
                <p id="debug-upload-help" class="text-muted small">The file is uploaded to server-side storage and treated as sensitive troubleshooting input. PNG, JPEG, and WebP are supported.</p>
                <InputFile id="debugFileInput" OnChange="HandleFileSelectedAsync" accept=".png,.jpg,.jpeg,.webp,image/png,image/jpeg,image/webp" class="form-control" aria-describedby="debug-upload-status" />
                <div id="debug-upload-status" class="form-text" aria-live="polite">@_uploadStatusText</div>
            </fieldset>

            <div class="mt-3">
                <label class="form-label" for="issueSummary">Visible Issue Summary</label>
                <InputTextArea id="issueSummary" class="form-control" @bind-Value="_request.VisibleIssueSummary" aria-describedby="issue-summary-help" />
                <div id="issue-summary-help" class="form-text">State only what is visibly wrong or missing in the screenshot.</div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <label class="form-label" for="dataSourceName">Data Source Name</label>
                    <InputText id="dataSourceName" class="form-control" @bind-Value="_request.DataSourceName" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="dataSourceCategory">Data Source Category</label>
                    <InputText id="dataSourceCategory" class="form-control" @bind-Value="_request.DataSourceCategory" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="resolutionStatus">Resolution Status</label>
                    <InputSelect id="resolutionStatus" class="form-select" @bind-Value="_request.ResolutionStatus">
                        <option value="unknown">Unknown</option>
                        <option value="planned">Planned</option>
                        <option value="connected">Connected</option>
                        <option value="failing">Failing</option>
                    </InputSelect>
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label" for="clarificationNotes">Clarification Notes</label>
                <InputTextArea id="clarificationNotes" class="form-control" @bind-Value="_request.ClarificationNotes" />
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <small class="text-muted" aria-live="polite">Latest data-source status: @(DataSourceContext?.ResolutionStatus ?? "unknown")</small>
                <button type="submit" class="btn btn-outline-primary">Save Debugging Context</button>
            </div>
        </EditForm>
    </div>
</section>

@code {
    private string _uploadStatusText = "No screenshot artifact selected yet.";
    private readonly DebuggingContextRequest _request = new() { ResolutionStatus = "unknown" };

    [Parameter]
    public DataSourceContext? DataSourceContext { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<DebuggingContextRequest> OnSaved { get; set; }

    protected override void OnParametersSet()
    {
        _request.DataSourceName = DataSourceContext?.DataSourceName ?? string.Empty;
        _request.DataSourceCategory = DataSourceContext?.DataSourceCategory ?? string.Empty;
        _request.ResolutionStatus = DataSourceContext?.ResolutionStatus ?? "unknown";
        _request.ClarificationNotes = DataSourceContext?.ClarificationNotes ?? string.Empty;
    }

    private async Task HandleFileSelectedAsync(InputFileChangeEventArgs eventArgs)
    {
        var browserFile = eventArgs.File;

        try
        {
            await using var fileStream = browserFile.OpenReadStream(UntrustedInputGuard.MaxScreenshotBytes);
            using var memoryStream = new MemoryStream();
            await fileStream.CopyToAsync(memoryStream);

            _request.ScreenshotContent = memoryStream.ToArray();
            _request.ScreenshotFileName = browserFile.Name;
            _request.ScreenshotContentType = browserFile.ContentType;
            _request.ScreenshotFileSize = browserFile.Size;
            _uploadStatusText = $"{browserFile.Name} selected for secure server-side upload ({browserFile.Size} bytes).";
        }
        catch (Exception exception)
        {
            _request.ScreenshotContent = null;
            _uploadStatusText = $"Screenshot selection failed: {exception.Message}";
        }
    }

    private Task HandleSubmitAsync()
    {
        return OnSaved.InvokeAsync(_request);
    }
}