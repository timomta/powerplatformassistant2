@inherits LayoutComponentBase
@inject IWebHostEnvironment WebHostEnvironment
@inject Microsoft.Extensions.Options.IOptions<LocalDevelopmentAuthenticationOptions> LocalDevelopmentAuthentication

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        @if (WebHostEnvironment.IsDevelopment() && LocalDevelopmentAuthentication.Value.Enabled)
        {
            <div class="alert alert-warning border-0 rounded-0 mb-0" role="status">
                Development mode is using the local auto-sign-in profile for <strong>@LocalDevelopmentAuthentication.Value.DisplayName</strong>
                in tenant <strong>@LocalDevelopmentAuthentication.Value.TenantId</strong> and environment <strong>@LocalDevelopmentAuthentication.Value.EnvironmentId</strong>.
            </div>
        }

        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
