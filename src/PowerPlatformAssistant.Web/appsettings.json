{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Governance": {
    "PolicyAuthority": "organizational policy authority",
    "ConversationAccessPolicy": "AuthenticatedSessionOnly",
    "ScreenshotAccessPolicy": "PolicyAuthorizedReviewersOnly",
    "ChatRetentionDays": 0,
    "ScreenshotRetentionDays": 0,
    "DisposalWorkflow": "PolicyDefinedDisposalRequired",
    "RequireComplianceReview": true
  }
}
